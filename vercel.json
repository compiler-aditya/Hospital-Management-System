{
  "version": 2,
  "builds": [
    {
      "src": "run.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "15mb", "runtime": "python3.9" }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "run.py"
    }
  ],
  "installCommand": "pip install -r requirements.txt",
  "buildCommand": "echo 'No specific build command needed for Flask'",
  "devCommand": "python run.py"
}